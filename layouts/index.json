[
{{- $pages := where .Site.RegularPages "Type" "in" (slice "posts" "page") -}}
{{- range $i, $p := $pages -}}
{{- if $i }},{{ end }}
{"title":{{ $p.Title | jsonify }},"url":{{ $p.RelPermalink | jsonify }},"date":{{ $p.Date.Format "2006-01-02" | jsonify }},"summary":{{ ($p.Summary | plainify | htmlUnescape) | jsonify }}}
{{- end -}}
]
